<Window x:Class="MortysDLP.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MortysDLP"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Icon="/Resources/Icons/mw_globe_32px.ico"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Width="400" Height="220"
        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
        AllowsTransparency="False"
        ShowInTaskbar="True">

    <!-- Äußere Card mit abgerundeten Ecken -->
    <Border Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
            CornerRadius="14"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Gradient-Akzentstreifen -->
                <RowDefinition Height="5"/>
                <!-- Hauptinhalt -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Akzentstreifen oben: Gelb → Orange -->
            <Rectangle Grid.Row="0"
                       Fill="{StaticResource BrandGradientBrush}"/>

            <!-- Hauptinhalt -->
            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="28,14,28,18">

                <!-- Logo mit gelbem Ring -->
                <Border x:Name="LogoBorder"
                        Width="58"
                        Height="58"
                        CornerRadius="29"
                        Background="#252831"
                        BorderBrush="{StaticResource BrandYellowBrush}"
                        BorderThickness="2"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,12">
                    <Image x:Name="LogoImage"
                           Width="42" Height="42"
                           Source="/Resources/Logos/globus.png"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                </Border>

                <!-- Titel -->
                <TextBlock x:Name="TitleText"
                           FontSize="17"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Spinner + Status in einer Zeile -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <!-- Rotierendes Ladeicon (Gelb) -->
                    <TextBlock x:Name="LoadingIcon"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="15"
                               Text="&#xE895;"
                               Foreground="{StaticResource BrandYellowBrush}"
                               VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5"
                               Margin="0,0,8,0">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="LoadingRotation"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>

                    <!-- Statustext -->
                    <TextBlock x:Name="StatusText"
                               Text=""
                               FontSize="12"
                               Opacity="0.72"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="300"/>
                </StackPanel>

            </StackPanel>
        </Grid>
    </Border>
</Window>
