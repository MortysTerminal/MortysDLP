<Window x:Class="MortysDLP.Views.WhisperModelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Whisper-Modelle verwalten"
        Width="760" Height="600"
        MinWidth="680" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="txtHeaderTitle" FontSize="20" FontWeight="Bold"/>
            <TextBlock x:Name="txtHeaderSubtitle" Opacity="0.65" Margin="0,2,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Whisper Engine Status -->
        <Border Grid.Row="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,10"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="txtWhisperEngineStatus" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtModelsDir" Opacity="0.6" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnUninstall" Click="btnUninstall_Click" Margin="0,0,8,0"
                            Foreground="#EF4444" Visibility="Collapsed"/>
                    <Button x:Name="btnInstallWhisper" Click="btnInstallWhisper_Click"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Download-Fortschritt -->
        <Border Grid.Row="2" x:Name="pnlProgress" Visibility="Collapsed"
                CornerRadius="8" Padding="14,10" Margin="0,0,0,10"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="txtProgressLabel" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ProgressBar x:Name="pbProgress"
                             Style="{StaticResource FluentProgressBarStyle}"
                             Height="10" Minimum="0" Maximum="100" Value="0"/>
                <TextBlock x:Name="txtProgressPercent" Margin="0,4,0,0" Opacity="0.7"/>
            </StackPanel>
        </Border>

        <!-- Modell-Liste -->
        <ScrollViewer x:Name="scrollModels" Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <ItemsControl x:Name="icModels">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8" Padding="14,10" Margin="0,0,0,6"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Name + Beschreibung -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}" Opacity="0.65" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Größe -->
                                <TextBlock Grid.Column="1" Text="{Binding SizeHint}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Opacity="0.75"/>

                                <!-- Status -->
                                <TextBlock Grid.Column="2" Text="{Binding StatusText}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding StatusColor}"/>

                                <!-- Aktions-Buttons -->
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="{Binding DownloadButtonText}"
                                            IsEnabled="{Binding CanDownload}"
                                            Visibility="{Binding DownloadVisibility}"
                                            Tag="{Binding ModelId}"
                                            Click="btnDownloadModel_Click"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Margin="0,0,6,0" Padding="8,4"/>
                                    <Button Content="{Binding DeleteButtonText}"
                                            IsEnabled="{Binding CanDelete}"
                                            Visibility="{Binding DeleteVisibility}"
                                            Tag="{Binding ModelId}"
                                            Click="btnDeleteModel_Click"
                                            Padding="8,4"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Trennlinie -->
        <Separator Grid.Row="4" Margin="0,0,0,10"/>

        <!-- Footer -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnClose" Click="btnClose_Click" MinWidth="90"/>
        </StackPanel>
    </Grid>
</Window>
