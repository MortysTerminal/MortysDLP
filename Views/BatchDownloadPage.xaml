<Page x:Class="MortysDLP.Views.BatchDownloadPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Batch-Download"
      Loaded="BatchDownloadPage_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0">

            <!-- DOWNLOAD-PFADE -->
            <Border CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="txtSectionDownloadPaths" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource BrandOrangeBrush}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <Label x:Name="lblDownloadPathInfo" VerticalAlignment="Center" Padding="2" MinWidth="150"/>
                        <Label x:Name="lblDownloadPath" MinWidth="400" Cursor="Hand"
                               Foreground="{StaticResource BrandYellowBrush}"
                               MouseLeftButtonUp="DownloadPath_MouseLeftButtonUp"/>
                        <Button x:Name="btnChangeDownloadPath" Click="btnChangeDownloadPath_Click"
                                Margin="8,0,0,0" Padding="8,3"/>
                    </StackPanel>
                    <DockPanel x:Name="dpAudioPath">
                        <StackPanel Orientation="Horizontal">
                            <Label x:Name="lblAudioPathInfo" VerticalAlignment="Center" Padding="2" MinWidth="150"/>
                            <Label x:Name="lblAudioPath" MinWidth="400" Cursor="Hand"
                                   Foreground="{StaticResource BrandYellowBrush}"
                                   MouseLeftButtonUp="DownloadPath_MouseLeftButtonUp"/>
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- URL-LISTE -->
            <Border CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="txtSectionUrlList" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource BrandOrangeBrush}" Margin="0,0,0,8"/>

                    <!-- URL-Eingabe -->
                    <Grid Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Hint -->
                            <RowDefinition Height="Auto"/>
                            <!-- Label + Inputs -->
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <!-- Label -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Inputs -->
                        </Grid.ColumnDefinitions>

                        <!-- Hint sitzt in Spalte 1 -> automatisch über der Textbox -->
                        <TextBlock x:Name="txtUrlHint"
                           Grid.Row="0" Grid.Column="1"
                           Visibility="Hidden"
                           Foreground="{StaticResource BrandYellowBrush}"
                           FontSize="11"
                           FontStyle="Italic"
                           Margin="7,-22,0,2"/>       

                        <!-- Label in Spalte 0 -->
                        <Label x:Name="lblAddUrl"
                           Grid.Row="1" Grid.Column="0"
                           VerticalAlignment="Center"
                           Padding="2"
                           MinWidth="100"/>         

                        <!-- Textbox + Buttons in Spalte 1 -->
                        <StackPanel Grid.Row="1" Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="7,0,0,0">
                            <TextBox x:Name="tbAddUrl" Width="440" VerticalContentAlignment="Center"
                                 KeyDown="tbAddUrl_KeyDown" TextChanged="tbAddUrl_TextChanged"/>
                            <Button x:Name="btnAddUrl" Click="btnAddUrl_Click" MinWidth="100" Padding="12,5" Margin="7,0,0,0" IsEnabled="False"/>
                            <Button x:Name="btnAddBatchUrl" Click="btnAddBatchUrl_Click" MinWidth="100" Padding="12,5" Margin="7,0,0,0"/>
                            <Button x:Name="btnHistory" Click="btnHistory_Click" MinWidth="100" Padding="12,5" Margin="7,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Tabelle -->
                    <Grid MinHeight="160" MaxHeight="380" Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="dgUrls"
                                  Grid.Row="0"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  CanUserReorderColumns="False"
                                  CanUserResizeRows="False"
                                  HeadersVisibility="Column"
                                  Margin="0,0,0,6"
                                  PreviewKeyDown="dgUrls_PreviewKeyDown"
                                  SelectionChanged="dgUrls_SelectionChanged">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Name="ctxRequeue" Click="ctxRequeue_Click" Header="Re-queue"/>
                                    <MenuItem x:Name="ctxDownloadSelected" Click="ctxDownloadSelected_Click" Header="Download Selected Now"/>
                                    <Separator/>
                                    <MenuItem x:Name="ctxRemove" Click="btnRemoveSelected_Click" Header="Remove"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="30">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="14" FontWeight="Bold"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center" 
                                                       Foreground="{Binding IconColor}" Margin="0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn x:Name="colStatus" Binding="{Binding Status}" Width="150"/>
                                <DataGridTextColumn x:Name="colUrl" Binding="{Binding Url}" Width="2*"/>
                                <DataGridTextColumn x:Name="colTitle" Binding="{Binding Title}" Width="3*"/>
                                <DataGridTemplateColumn x:Name="colProgress" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="14" Margin="4,3"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right">
                            <Button x:Name="btnRequeueDone" Click="btnRequeueDone_Click" MinWidth="100" Padding="12,5" Margin="0,0,8,0" IsEnabled="False"/>
                            <Button x:Name="btnRemoveSelected" Click="btnRemoveSelected_Click" MinWidth="100" Padding="12,5" Margin="0,0,8,0" IsEnabled="False"/>
                            <Button x:Name="btnClearList" Click="btnClearList_Click" MinWidth="100" Padding="12,5" IsEnabled="False"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- OPTIONEN -->
            <Border CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="txtSectionOptions" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource BrandOrangeBrush}" Margin="0,0,0,8"/>

                    <!-- Audio Only -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox x:Name="cbAudioOnly" IsChecked="False"
                                  Checked="cbAudioOnlyCheck" Unchecked="cbAudioOnlyCheck"
                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="txtAudioOnlyInfo" VerticalAlignment="Center" MinWidth="100"/>
                        <ComboBox x:Name="combAudioFormat" Width="100" SelectedIndex="4" Margin="8,0,0,0" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="aac"/>
                            <ComboBoxItem Content="alac"/>
                            <ComboBoxItem Content="flac"/>
                            <ComboBoxItem Content="m4a"/>
                            <ComboBoxItem Content="mp3"/>
                            <ComboBoxItem Content="opus"/>
                            <ComboBoxItem Content="vorbis"/>
                            <ComboBoxItem Content="wav"/>
                        </ComboBox>
                        <TextBlock x:Name="txtBitrateLabel" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        <ComboBox x:Name="combAudioBitrate" Width="120" SelectedIndex="3" Margin="7,0,0,0" VerticalContentAlignment="Center">
                            <ComboBoxItem x:Name="cbiAudioBitrateHighest"/>
                            <ComboBoxItem Content="320k"/>
                            <ComboBoxItem Content="256k"/>
                            <ComboBoxItem Content="192k"/>
                            <ComboBoxItem Content="160k"/>
                            <ComboBoxItem Content="128k"/>
                            <ComboBoxItem Content="96k"/>
                            <ComboBoxItem Content="64k"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Videoqualität + Container -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="txtVideoQuality" VerticalAlignment="Center" MinWidth="100" Margin="28,0,0,0"/>
                        <ComboBox x:Name="combVideoQuality" Width="150" SelectedIndex="0" Margin="8,0,0,0" VerticalContentAlignment="Center">
                            <ComboBoxItem x:Name="cbiVideoQualityHighest" Tag="best"/>
                            <ComboBoxItem Content="1440p" Tag="1440"/>
                            <ComboBoxItem Content="1080p" Tag="1080"/>
                            <ComboBoxItem Content="720p" Tag="720"/>
                            <ComboBoxItem Content="480p" Tag="480"/>
                            <ComboBoxItem Content="360p" Tag="360"/>
                            <ComboBoxItem Content="240p" Tag="240"/>
                            <ComboBoxItem Content="144p" Tag="144"/>
                        </ComboBox>
                        <TextBlock x:Name="txtVideoContainer" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        <ComboBox x:Name="combVideoFormat" Width="100" SelectedIndex="0" Margin="8,0,0,0" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="mp4"/>
                            <ComboBoxItem Content="mkv"/>
                            <ComboBoxItem Content="mov"/>
                            <ComboBoxItem Content="avi"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- x264 für Schnittprogramme -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <CheckBox x:Name="cbVideoformat" IsChecked="False"
                                  Checked="cbVideoFormatCheck" Unchecked="cbVideoFormatCheck"
                                  VerticalAlignment="Center" Margin="28,0,8,0"/>
                        <TextBlock x:Name="txtVideoformatInfo1" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtVideoformatInfo2" VerticalAlignment="Center" Opacity="0.6" Margin="4,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- BANDWIDTH-HINWEIS -->
            <Border x:Name="borderBandwidthHint" CornerRadius="8" Padding="10,7" Margin="0,0,0,8"
                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" Visibility="Collapsed">
                <TextBlock x:Name="txtBandwidthHint" TextWrapping="Wrap" FontSize="11" Opacity="0.8"/>
            </Border>

            <!-- AKTIONEN + FORTSCHRITT -->
            <Border CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnStartAll" Click="btnStartAll_Click" MinWidth="100" Padding="12,5"
                            Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Center" IsEnabled="False"/>
                    <Button x:Name="btnCancelAll" Click="btnCancelAll_Click" IsEnabled="False" MinWidth="100" Padding="12,5"
                            VerticalAlignment="Center" Margin="7,0,0,0"/>
                    <Border Padding="12,0,0,0">
                        <StackPanel x:Name="spOverallProgress" Visibility="Hidden" Orientation="Vertical" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="4,0,4,4">
                                <TextBlock x:Name="txtOverallStatus" FontWeight="Bold"/>
                                <TextBlock x:Name="txtOverallCount" Margin="8,0,0,0"
                                           Foreground="{StaticResource BrandOrangeBrush}" FontWeight="Bold"/>
                                <TextBlock x:Name="txtOverallPercent" Margin="8,0,0,0" Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ProgressBar x:Name="pbOverall"
                                             Style="{StaticResource FluentProgressBarStyle}"
                                             Width="200" Height="11"
                                             Minimum="0" Maximum="100" Value="0"/>
                                <TextBlock x:Name="txtCurrentSpeed" Margin="8,0,0,0" Opacity="0.7" FontSize="11"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="btnOpenFolder" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                        Background="Transparent" BorderThickness="0" Padding="0" Margin="6,0,0,0"
                                        Click="btnOpenFolder_Click" Visibility="Collapsed">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Text="&#xE8B7;"
                                               Foreground="{StaticResource BrandYellowBrush}"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- DEBUG -->
            <DockPanel Margin="0,2,0,0">
                <Expander x:Name="expDebug" IsExpanded="False">
                    <TextBox x:Name="tbDebugOutput" VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" IsReadOnly="True" TextWrapping="NoWrap"
                             FontFamily="Consolas" FontSize="12" AcceptsReturn="True" AcceptsTab="True"
                             MaxHeight="200" TextChanged="tbDebugOutput_TextChanged"/>
                </Expander>
            </DockPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
