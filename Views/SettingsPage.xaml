<Page x:Class="MortysDLP.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Einstellungen"
      Loaded="SettingsPage_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0">

            <!-- DOWNLOAD-PFADE -->
            <Border CornerRadius="8" Padding="14,10,14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="txtSectionDownloadPaths" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource BrandOrangeBrush}" Margin="0,0,0,8"/>
                    <Button x:Name="btnChangeDownloadPath" Click="btnChangeDownloadPath_Click"
                            Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- APP -->
            <Border CornerRadius="8" Padding="14,10,14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="txtSectionApp" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource BrandOrangeBrush}" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <Button x:Name="btnGitHub" Click="btnGitHub_Click" Margin="0,0,8,0"/>
                        <Button x:Name="btnClose" Click="btnClose_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- DEBUG -->
            <Border CornerRadius="8" Padding="14,10,14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="txtSectionDebug" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource BrandOrangeBrush}" Margin="0,0,0,8"/>
                    <CheckBox x:Name="cbDebugMode"
                              Checked="cbDebugMode_Changed" Unchecked="cbDebugMode_Changed"/>
                </StackPanel>
            </Border>

            <!-- LANGUAGE -->
            <Border CornerRadius="8" Padding="14,10,14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="txtSectionLanguage" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource BrandOrangeBrush}" Margin="0,0,0,8"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Label x:Name="lblSelectLanguage" VerticalAlignment="Center" MinWidth="150"/>
                        <ComboBox x:Name="cbLanguage" Width="200" SelectionChanged="cbLanguage_SelectionChanged"/>
                    </StackPanel>
                    
                    <TextBlock x:Name="txtLanguageInfo" Opacity="0.7" Margin="0,5,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
