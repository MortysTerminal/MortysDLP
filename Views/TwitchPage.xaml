<Page x:Class="MortysDLP.Views.TwitchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Twitch VOD-Download"
      Loaded="TwitchPage_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0">

            <!-- INFO -->
            <Border CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="txtSectionInfo" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource BrandOrangeBrush}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="txtInfoText" TextWrapping="Wrap" LineHeight="20" Opacity="0.9"/>
                </StackPanel>
            </Border>

            <!-- TWITCHDOWNLOADERCLI STATUS -->
            <Border CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="txtSectionTool" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource BrandOrangeBrush}" Margin="0,0,0,10"/>

                    <TextBlock x:Name="txtToolStatus" TextWrapping="Wrap" Margin="0,0,0,4" Opacity="0.85"/>
                    <TextBlock x:Name="txtFileSize" TextWrapping="Wrap" Margin="0,0,0,10"
                               Opacity="0.55" FontSize="11" Visibility="Collapsed"/>

                    <!-- Update-Hinweis (dezent, nur sichtbar wenn Update verfügbar) -->
                    <Border x:Name="pnlUpdateHint" CornerRadius="6" Padding="10,8" Margin="0,0,0,10"
                            Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="15"
                                       VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource BrandOrangeBrush}"/>
                            <TextBlock x:Name="txtUpdateHint" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <!-- Nur sichtbar solange nicht installiert -->
                        <Button x:Name="btnInstall" Click="btnInstall_Click" MinWidth="120" Padding="12,5"
                                Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                        <!-- Sichtbar wenn installiert: adaptiver Update/Check-Button -->
                        <Button x:Name="btnUpdateAction" Click="btnUpdateAction_Click" MinWidth="180" Padding="12,5"
                                Margin="0,0,8,0" Visibility="Collapsed" IsEnabled="False"/>
                        <Button x:Name="btnUninstall" Click="btnUninstall_Click" MinWidth="120" Padding="12,5"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- VOD-DOWNLOAD -->
            <Border x:Name="borderDownload" CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="txtSectionDownload" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource BrandOrangeBrush}" Margin="0,0,0,8"/>

                    <!-- URL / ID -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Label x:Name="lblURL" VerticalAlignment="Center" Padding="2" MinWidth="180"/>
                        <TextBox x:Name="tbURL" Width="480" VerticalContentAlignment="Center" Margin="7,0,0,0"
                                 TextChanged="tbURL_TextChanged"/>
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Text="&#xE946;" Opacity="0.8" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock.ToolTip>
                                <ToolTip x:Name="tooltipURL"/>
                            </TextBlock.ToolTip>
                        </TextBlock>
                    </StackPanel>

                    <!-- Ausgabeordner -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Label x:Name="lblOutputPath" VerticalAlignment="Center" Padding="2" MinWidth="180"/>
                        <TextBox x:Name="tbOutputPath" Width="310" IsReadOnly="True" VerticalContentAlignment="Center"
                                 Margin="7,0,7,0"
                                 ToolTip="{Binding ElementName=tbOutputPath, Path=Text}"/>
                        <Button x:Name="btnUseGlobalPath" Click="btnUseGlobalPath_Click" MinWidth="100" Padding="12,5"
                                Margin="0,0,7,0"/>
                        <Button x:Name="btnBrowseOutput" Click="btnBrowseOutput_Click" MinWidth="100" Padding="12,5"/>
                        <Button x:Name="btnOpenOutput" Click="btnOpenOutput_Click" MinWidth="100" Padding="12,5"
                                Margin="7,0,0,0" IsEnabled="False"/>
                    </StackPanel>

                    <!-- Video-Download-Option -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox x:Name="cbDownloadVideo" IsChecked="True" VerticalAlignment="Center" Margin="0,0,8,0"
                                  Checked="cbDownloadVideo_Changed" Unchecked="cbDownloadVideo_Changed"/>
                        <TextBlock x:Name="txtDownloadVideo" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Text="&#xE946;" Opacity="0.8" VerticalAlignment="Center" Margin="2,0,0,0">
                            <TextBlock.ToolTip>
                                <ToolTip x:Name="tooltipDownloadVideo"/>
                            </TextBlock.ToolTip>
                        </TextBlock>
                    </StackPanel>

                    <!-- Chat-Download-Option -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox x:Name="cbDownloadChat" VerticalAlignment="Center" Margin="0,0,8,0"
                                  Checked="cbDownloadChat_Changed" Unchecked="cbDownloadChat_Changed"/>
                        <TextBlock x:Name="txtDownloadChat" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Text="&#xE946;" Opacity="0.8" VerticalAlignment="Center" Margin="2,0,0,0">
                            <TextBlock.ToolTip>
                                <ToolTip x:Name="tooltipDownloadChat"/>
                            </TextBlock.ToolTip>
                        </TextBlock>
                    </StackPanel>

                    <!-- Chat-Format-Auswahl (nur sichtbar wenn Chat-Download aktiv) -->
                    <StackPanel x:Name="pnlChatOptions" Orientation="Vertical"
                                Margin="24,0,0,0" Visibility="Collapsed">
                        <!-- Option 1: Nur JSON -->
                        <RadioButton x:Name="rbChatJson" GroupName="ChatMode"
                                     IsChecked="True" VerticalAlignment="Center" Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtChatJson" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15"
                                           Text="&#xE946;" Opacity="0.7" VerticalAlignment="Center">
                                    <TextBlock.ToolTip>
                                        <ToolTip x:Name="tooltipChatJson"/>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </StackPanel>
                        </RadioButton>

                        <!-- Option 2: Als Video rendern -->
                        <RadioButton x:Name="rbChatRender" GroupName="ChatMode"
                                     VerticalAlignment="Center" Margin="0,0,0,6"
                                     Checked="rbChatRender_Changed" Unchecked="rbChatRender_Changed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtChatRender" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15"
                                           Text="&#xE946;" Opacity="0.7" VerticalAlignment="Center">
                                    <TextBlock.ToolTip>
                                        <ToolTip x:Name="tooltipChatRender"/>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </StackPanel>
                        </RadioButton>

                        <!-- Render-Qualität (nur sichtbar wenn "Als Video rendern") -->
                        <StackPanel x:Name="pnlRenderQuality" Orientation="Horizontal"
                                    Margin="0,0,0,6" Visibility="Collapsed">
                            <Label x:Name="lblRenderQuality" VerticalAlignment="Center" Padding="0,0,8,0"/>
                            <ComboBox x:Name="cbRenderQuality" Width="160" VerticalContentAlignment="Center">
                                <ComboBoxItem x:Name="cbiQualityStandard" IsSelected="True"/>
                                <ComboBoxItem x:Name="cbiQualityHigh"/>
                                <ComboBoxItem x:Name="cbiQualityUltra"/>
                            </ComboBox>
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15"
                                       Text="&#xE946;" Opacity="0.7" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock.ToolTip>
                                    <ToolTip x:Name="tooltipRenderQuality"/>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </StackPanel>

                        <!-- GPU-Warnhinweis (nur bei "Als Video rendern") -->
                        <Border x:Name="pnlGpuHint" CornerRadius="6" Padding="10,7" Margin="0,0,0,4"
                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7BA;" FontSize="15"
                                           VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="{StaticResource BrandOrangeBrush}"/>
                                <TextBlock x:Name="txtGpuHint" TextWrapping="Wrap" VerticalAlignment="Center"
                                           Opacity="0.9" MaxWidth="480"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- BANDWIDTH-HINWEIS -->
            <Border x:Name="borderBandwidthHint" CornerRadius="8" Padding="10,7" Margin="0,0,0,8"
                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" Visibility="Collapsed">
                <TextBlock x:Name="txtBandwidthHint" TextWrapping="Wrap" FontSize="11" Opacity="0.8"/>
            </Border>

            <!-- AKTIONEN + FORTSCHRITT -->
            <Border CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnStart" Click="btnStart_Click" MinWidth="100" Padding="12,5"
                            Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Center"/>
                    <Button x:Name="btnCancel" Click="btnCancel_Click" IsEnabled="False" MinWidth="100" Padding="12,5"
                            VerticalAlignment="Center" Margin="7,0,0,0"/>
                    <Border Padding="12,0,0,0">
                        <StackPanel x:Name="spLoadingbar" Visibility="Hidden" Orientation="Vertical" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="4,0,4,4">
                                <TextBlock x:Name="txtDownloadStatus" FontWeight="Bold"/>
                                <TextBlock x:Name="txtDownloadSpeed" Margin="8,0,0,0" Opacity="0.7" FontSize="12"/>
                            </StackPanel>
                            <ProgressBar x:Name="pbDownload"
                                         Style="{StaticResource FluentProgressBarStyle}"
                                         Width="200" Height="11"
                                         IsIndeterminate="True"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- DEBUG -->
            <DockPanel Margin="0,2,0,0">
                <Expander x:Name="expDebug" IsExpanded="False">
                    <TextBox x:Name="tbDebugOutput" VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" IsReadOnly="True" TextWrapping="NoWrap"
                             FontFamily="Consolas" FontSize="12" AcceptsReturn="True" AcceptsTab="True"
                             MaxHeight="200" TextChanged="tbDebugOutput_TextChanged"/>
                </Expander>
            </DockPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
