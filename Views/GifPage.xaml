<Page x:Class="MortysDLP.Views.GifPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="GIF-Maker"
      Loaded="GifPage_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0">

            <!-- INFO -->
            <Border CornerRadius="8" Padding="14,10,14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="txtSectionInfo" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource BrandOrangeBrush}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="txtInfoText" TextWrapping="Wrap" LineHeight="20" Opacity="0.9"/>
                </StackPanel>
            </Border>

            <!-- EINGABEDATEI -->
            <Border CornerRadius="8" Padding="14,10,14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    AllowDrop="True" Drop="borderInput_Drop" DragOver="borderInput_DragOver">
                <StackPanel>
                    <TextBlock x:Name="txtSectionInput" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource BrandOrangeBrush}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label x:Name="lblInputFile" VerticalAlignment="Center" Padding="2" MinWidth="170"/>
                        <TextBox x:Name="tbInputFile" Width="430" IsReadOnly="True"
                                 VerticalContentAlignment="Center" Margin="7,0,7,0"
                                 ToolTip="{Binding ElementName=tbInputFile, Path=Text}">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <Button x:Name="btnBrowseInput" Click="btnBrowseInput_Click">
                            <TextBlock x:Name="txtBrowseInput"/>
                        </Button>
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Text="&#xE946;" Opacity="0.8" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock.ToolTip>
                                <ToolTip x:Name="tooltipInputFile"/>
                            </TextBlock.ToolTip>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- EINSTELLUNGEN -->
            <Border CornerRadius="8" Padding="14,10,14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="txtSectionSettings" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource BrandOrangeBrush}" Margin="0,0,0,8"/>

                    <!-- Qualität -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Label x:Name="lblQuality" VerticalAlignment="Center" Padding="2" MinWidth="170"/>
                        <ComboBox x:Name="combQuality" Width="240" Margin="7,0,0,0" VerticalContentAlignment="Center">
                            <ComboBoxItem x:Name="cbiQualityWeb" IsSelected="True"/>
                            <ComboBoxItem x:Name="cbiQualityLow"/>
                            <ComboBoxItem x:Name="cbiQualityMedium"/>
                            <ComboBoxItem x:Name="cbiQualityHigh"/>
                        </ComboBox>
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Text="&#xE946;" Opacity="0.8" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock.ToolTip>
                                <ToolTip x:Name="tooltipQuality"/>
                            </TextBlock.ToolTip>
                        </TextBlock>
                    </StackPanel>

                    <!-- Zeitbereich -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <CheckBox x:Name="cbTimeRange" VerticalAlignment="Center" Margin="0,0,8,0"
                                  Checked="cbTimeRange_Check" Unchecked="cbTimeRange_Check"/>
                        <Label x:Name="lblStartTime" VerticalAlignment="Center" Padding="2" MinWidth="100"/>
                        <TextBox x:Name="tbStartTime" Width="100" IsEnabled="False" VerticalContentAlignment="Center" Margin="7,0,20,0"/>
                        <Label x:Name="lblEndTime" VerticalAlignment="Center" Padding="2" MinWidth="80"/>
                        <TextBox x:Name="tbEndTime" Width="100" IsEnabled="False" VerticalContentAlignment="Center" Margin="7,0,0,0"/>
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Text="&#xE946;" Opacity="0.8" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock.ToolTip>
                                <ToolTip x:Name="tooltipTime"/>
                            </TextBlock.ToolTip>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- AUSGABE -->
            <Border CornerRadius="8" Padding="14,10,14,12" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="txtSectionOutput" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource BrandOrangeBrush}" Margin="0,0,0,8"/>

                    <!-- Ausgabeordner -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label x:Name="lblOutputFolder" VerticalAlignment="Center" Padding="2"
                               MinWidth="170" Grid.Column="0"/>
                        <TextBox x:Name="tbOutputFolder" VerticalContentAlignment="Center"
                                 Margin="7,0,0,0" Grid.Column="1"/>
                        <Button x:Name="btnBrowseOutput" Click="btnBrowseOutput_Click"
                                Margin="7,0,0,0" Grid.Column="2">
                            <TextBlock x:Name="txtBrowseOutput"/>
                        </Button>
                        <Button x:Name="btnOpenOutput" Click="btnOpenOutput_Click"
                                Margin="7,0,0,0" Grid.Column="3">
                            <TextBlock x:Name="txtOpenOutput"/>
                        </Button>
                    </Grid>

                    <!-- Pfad übernehmen -->
                    <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="5" Padding="10"
                            Background="{DynamicResource LayerFillColorDefaultBrush}"
                            Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock x:Name="txtUsePath" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnUseDownloadPath" Click="btnUseDownloadPath_Click" Width="140">
                                    <TextBlock x:Name="txtUseDownloadPath"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- STEUERUNG + STATUS -->
            <Border CornerRadius="8" Padding="14,10,14,10" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnStart" Click="btnStart_Click"
                            Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0">
                        <TextBlock x:Name="txtBtnStart"/>
                    </Button>
                    <Button x:Name="btnCancel" Click="btnCancel_Click" IsEnabled="False">
                        <TextBlock x:Name="txtBtnCancel"/>
                    </Button>

                    <!-- Fortschritt (läuft) -->
                    <Border x:Name="pnlRunning" Padding="12,0,0,0" Visibility="Hidden">
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock x:Name="txtStatus" FontWeight="Bold"/>
                            </StackPanel>
                            <ProgressBar x:Name="pbProgress"
                                         Style="{StaticResource FluentProgressBarStyle}"
                                         Width="220" Height="8"
                                         Minimum="0" Maximum="100" Value="0"/>
                        </StackPanel>
                    </Border>

                    <!-- Ergebnis (fertig / Fehler / abgebrochen) -->
                    <Border x:Name="pnlResult" Padding="12,0,0,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="txtResultIcon" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="txtResultTitle" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button x:Name="btnOpenResult" Click="btnOpenResult_Click"
                                    Margin="12,0,0,0" Padding="6,3" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xED25;" FontSize="13"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock x:Name="txtOpenResult" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- DEBUG -->
            <DockPanel x:Name="borderDebug" Margin="0,2,0,0" Visibility="Collapsed">
                <Expander x:Name="expDebug" IsExpanded="False">
                    <TextBox x:Name="tbDebugOutput"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="12"
                             AcceptsReturn="True"
                             MaxHeight="200"/>
                </Expander>
            </DockPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
