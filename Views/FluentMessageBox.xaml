<Window x:Class="MortysDLP.FluentMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Resources/Icons/mw_globe_32px.ico"
        WindowStyle="None"
        AllowsTransparency="False"
         ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MinWidth="440"
        MaxWidth="640"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="4"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Gradient-Akzentstreifen -->
        <Rectangle Grid.Row="0" Fill="{StaticResource BrandGradientBrush}"/>

        <!-- Inhalt -->
        <Grid Grid.Row="1" Margin="24,20,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Icon + Titel -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="IconBorder"
                        Width="42" Height="42" CornerRadius="21"
                        VerticalAlignment="Center"
                        Margin="0,0,14,0">
                    <TextBlock x:Name="IconGlyph"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="21"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock x:Name="TitleBlock"
                           Grid.Column="1"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Grid>

            <!-- Nachricht -->
            <TextBlock x:Name="MessageBlock"
                       Grid.Row="1"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Opacity="0.85"
                       LineHeight="22"
                       Margin="0,0,0,22"/>

            <!-- Buttons -->
            <StackPanel x:Name="ButtonPanel"
                        Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</Window>
