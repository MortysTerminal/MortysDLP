<Window x:Class="MortysDLP.Views.UpdateChangelogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Resources/Icons/mw_globe_32px.ico"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        Width="560"
        Height="500"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="4"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Brand gradient accent bar -->
        <Rectangle Grid.Row="0" Fill="{StaticResource BrandGradientBrush}"/>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="24,20,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Icon + Title/Subtitle -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="48" Height="48" CornerRadius="24"
                        Background="#22e67e50"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE895;"
                               FontSize="22"
                               Foreground="{StaticResource BrandOrangeBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="txtTitle"
                               FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtSubtitle"
                               FontSize="12" Opacity="0.65" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Changelog label -->
            <TextBlock x:Name="txtChangelogLabel"
                       Grid.Row="1"
                       FontSize="11" FontWeight="SemiBold"
                       Opacity="0.55"
                       Margin="0,0,0,6"/>

            <!-- Changelog: rendered Markdown via RichTextBox -->
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                    ClipToBounds="True"
                    Margin="0,0,0,20">
                <RichTextBox x:Name="rtfChangelog"
                             IsReadOnly="True"
                             IsDocumentEnabled="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                             Padding="12,10"
                             FontSize="13"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="btnLater"
                        MinWidth="90"
                        Padding="20,8"
                        Margin="0,0,8,0"
                        Click="btnLater_Click"/>
                <Button x:Name="btnUpdateNow"
                        MinWidth="130"
                        Padding="20,8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="btnUpdateNow_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>