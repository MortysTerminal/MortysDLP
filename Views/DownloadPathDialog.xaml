<Window x:Class="MortysDLP.DownloadPathDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:uitexte = "clr-namespace:MortysDLP.UITexte"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Resources/Icons/mw_globe_32px.ico"
        Title="Download-Pfade konfigurieren"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        Width="600" Height="auto"
        SizeToContent="Height"
        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
        Closing="Window_Closing">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="txtHeaderTitle" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock x:Name="txtHeaderSubtitle" FontSize="12" Opacity="0.7" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Standard Download-Pfad -->
        <Border Grid.Row="1" CornerRadius="8" Padding="14" Margin="0,0,0,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Icon -->
                <TextBlock Grid.Column="0" Grid.RowSpan="2" FontFamily="Segoe MDL2 Assets" Text="&#xE838;" 
                           FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"
                           Foreground="{StaticResource BrandOrangeBrush}"/>
                
                <!-- Label -->
                <TextBlock Grid.Column="1" Grid.Row="0" Name="lblDefaultDownloadPath" 
                           Text="Standard Download-Pfad" FontWeight="SemiBold"/>
                
                <!-- TextBox + Button Row -->
                <Grid Grid.Column="1" Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox Grid.Column="0" Name="tbDownloadPath" Padding="10,8"/>
                    <Button Grid.Column="1" Name="btnDownloadPath"
                            Click="btnDownloadPath_Click" Margin="8,0,0,0" Padding="12,8"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Audio-Only Pfad Checkbox -->
        <Border Grid.Row="2" CornerRadius="8" Padding="14" Margin="0,0,0,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Icon -->
                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" Text="&#xE8D6;" 
                           FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"
                           Foreground="{StaticResource BrandYellowBrush}"/>
                
                <!-- Checkbox + Label -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Name="cbAudioOnlyPath"
                              Checked="cbAudioOnlyPath_Checked" 
                              Unchecked="cbAudioOnlyPath_Unchecked"
                              Cursor="Hand"/>
                    <TextBlock Name="lblDefaultAudioDownloadPath" 
                               VerticalAlignment="Center" 
                               Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Audio-Only Pfad Input (initially hidden) -->
        <Border Grid.Row="3" CornerRadius="8" Padding="14" Margin="0,0,0,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                x:Name="AudioPathPanel"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Icon -->
                <TextBlock Grid.Column="0" Grid.RowSpan="2" FontFamily="Segoe MDL2 Assets" Text="&#xE8D6;" 
                           FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"
                           Foreground="{StaticResource BrandYellowBrush}"/>
                
                <!-- Label -->
                <TextBlock Grid.Column="1" Grid.Row="0" x:Name="lblAudioOnlyPath"
                           FontWeight="SemiBold"/>
                
                <!-- TextBox + Button Row -->
                <Grid Grid.Column="1" Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox Grid.Column="0" Name="tbAudioPathBox" Padding="10,8"/>
                    <Button Grid.Column="1" Name="btnSearchAudioPath"
                            Click="btnSearchAudioPath_Click" Margin="8,0,0,0" Padding="12,8"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Separator -->
        <Separator Grid.Row="4" Margin="0,0,0,12" 
                   Background="{DynamicResource CardStrokeColorDefaultBrush}"/>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0">
            <Button Name="btnOK" Click="btnOK_Click" 
                    Style="{StaticResource PrimaryButtonStyle}" Padding="20,8" Margin="0,0,8,0"/>
            <Button Name="btnCancel" Click="btnCancel_Click" Padding="20,8"/>
        </StackPanel>
    </Grid>
</Window>
