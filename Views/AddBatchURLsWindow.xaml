<Window x:Class="MortysDLP.Views.AddBatchURLsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MortysDLP.Views"
        mc:Ignorable="d"
        Title="Mehrere URLs hinzufügen"
        Height="500" Width="700"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Überschrift -->
        <TextBlock Grid.Row="0"
                   Text="Mehrere URLs auf einmal hinzufügen"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- Beschreibung / Hinweis -->
        <TextBlock Grid.Row="1"
                   TextWrapping="Wrap"
                   Foreground="#555"
                   Margin="0,0,0,8"
                   Text="Füge unten pro Zeile eine URL ein (z. B. YouTube-Links). Leerzeilen sowie Einträge, die keine gültige URL sind, werden automatisch herausgefiltert."/>

        <!-- Eingabe-Textfeld -->
        <TextBox Grid.Row="2"
                 x:Name="txtUrls"
                 AcceptsReturn="True"
                 AcceptsTab="False"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="13"
                 Padding="5"
                 TextChanged="txtUrls_TextChanged"/>

        <!-- Status / Live-Vorschau -->
        <TextBlock Grid.Row="3"
                   x:Name="txtStatus"
                   Margin="0,8,0,0"
                   Foreground="Gray"
                   Text="0 Zeilen, 0 gültige URLs"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="btnOk"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Übernehmen"
                    Width="120" Height="32"
                    Margin="0,0,10,0"
                    IsDefault="True"
                    Click="btnOk_Click"/>
            <Button x:Name="btnCancel"
                    Content="Abbrechen"
                    Width="120" Height="32"
                    IsCancel="True"
                    Click="btnCancel_Click"/>
            
        </StackPanel>
    </Grid>
</Window>