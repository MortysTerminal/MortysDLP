<Window x:Class="MortysDLP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Resources/Icons/mw_globe_32px.ico"
        Title="MortysDLP"
        WindowStartupLocation="CenterScreen"
        Width="1120" Height="720"
        MinWidth="1050" MinHeight="680">

    <Window.Resources>
        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left accent bar (Windows 11 style) -->
                            <Border x:Name="AccentBar" Grid.Column="0"
                                    Background="Transparent"
                                    CornerRadius="0,2,2,0"/>

                            <!-- Content area -->
                            <Border x:Name="ContentBorder" Grid.Column="1"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="10,8">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ContentBorder" Property="Background" 
                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="AccentBar" Property="Background" 
                                        Value="{StaticResource BrandOrangeBrush}"/>
                                <Setter TargetName="ContentBorder" Property="Background" 
                                        Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ContentBorder" Property="Background" 
                                        Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" 
                BorderThickness="0,0,1,0">
            <Grid Margin="14,16,14,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo + App-Titel -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Width="38" Height="38" CornerRadius="19"
                            BorderBrush="{StaticResource BrandYellowBrush}" BorderThickness="1.5"
                            Background="#252A35">
                        <Image Source="/Resources/Logos/globus.png" Width="24" Height="24"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtAppTitle" FontWeight="Bold" FontSize="16"/>
                        <TextBlock x:Name="txtAppSubtitle" Opacity="0.6" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation -->
                <ListBox x:Name="NavigationList" Grid.Row="1"
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="NavigationList_SelectionChanged"
                         ItemContainerStyle="{StaticResource NavItemStyle}">
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,1">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE896;"
                                       VerticalAlignment="Center" Margin="0,0,10,0" FontSize="15"/>
                            <TextBlock x:Name="txtNavDownload" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,1">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B1;"
                                       VerticalAlignment="Center" Margin="0,0,10,0" FontSize="15"/>
                            <TextBlock x:Name="txtNavConvert" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,1">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;"
                                       VerticalAlignment="Center" Margin="0,0,10,0" FontSize="15"/>
                            <TextBlock x:Name="txtNavSettings" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <!-- joke: Support-Button unten links -->
                <Button x:Name="btnJokeDonate" Grid.Row="3"
                        Click="btnJokeDonate_Click"
                        Margin="0,0,0,0"
                        Padding="10,8"
                        HorizontalAlignment="Stretch"
                        Cursor="Hand"
                        ToolTip="Support this project ❤️">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="btnBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="btnBorder" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                <Setter TargetName="btnBorder" Property="BorderBrush"
                                                        Value="{StaticResource BrandYellowBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="btnBorder" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEB51;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="#e05c7a" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="txtJokeDonateTitle" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock x:Name="txtJokeDonateSubtitle" FontSize="10" Opacity="0.6"
                                       TextDecorations="Underline"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

            </Grid>
        </Border>

        <!-- INHALTSBEREICH -->
        <Grid Grid.Column="1" Margin="14,14,14,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Update-Banner (nur sichtbar wenn Update verfügbar) -->
            <Border x:Name="UpdateBanner"
                    Grid.Row="0"
                    Visibility="Collapsed"
                    CornerRadius="8"
                    Margin="0,0,0,8"
                    ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#2A1E00" Offset="0"/>
                        <GradientStop Color="#2A1000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Farbiger Akzentstreifen links -->
                    <Rectangle Grid.Column="0" Fill="{StaticResource BrandGradientBrush}"/>

                    <!-- Klickbarer Bereich mit Icon + Text -->
                    <Button Grid.Column="1"
                            x:Name="btnUpdateBanner"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="12,8"
                            HorizontalContentAlignment="Left"
                            Cursor="Hand"
                            Click="btnUpdateBanner_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg"
                                                    Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#15ffffff"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#25ffffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE895;"
                                       FontSize="15"
                                       Foreground="{StaticResource BrandYellowBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtUpdateBannerMain"
                                           FontWeight="SemiBold" FontSize="13"
                                           Foreground="{StaticResource BrandYellowBrush}"/>
                                <TextBlock x:Name="txtUpdateBannerSub"
                                           FontSize="11" Opacity="0.7"
                                           Foreground="{StaticResource BrandCreamBrush}"
                                           Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Schließen-Button -->
                    <Button Grid.Column="2"
                            x:Name="btnDismissBanner"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="36" Height="36"
                            Margin="0,0,4,0"
                            Cursor="Hand"
                            ToolTip="{Binding}"
                            Click="btnDismissBanner_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4"
                                                    Width="{TemplateBinding Width}"
                                                    Height="{TemplateBinding Height}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#20ffffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;"
                                   FontSize="12"
                                   Foreground="{StaticResource BrandCreamBrush}"
                                   Opacity="0.7"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Header-Leiste -->
            <Border Grid.Row="1" CornerRadius="10" ClipToBounds="True" Margin="0,0,0,10"
                    Background="{DynamicResource LayerFillColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Rectangle Grid.Row="0" Fill="{StaticResource BrandGradientBrush}"/>
                    <DockPanel Grid.Row="1" Margin="14,9,14,11">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center" Opacity="0.45">
                            <TextBlock x:Name="txtVersionLabel" FontStyle="Italic" VerticalAlignment="Center"/>
                            <TextBlock Name="lblMainVersion" FontStyle="Italic" VerticalAlignment="Center"
                                       Margin="4,0,0,0" Text="-"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Name="txtSectionTitle"
                                       FontWeight="Bold" FontSize="20"/>
                            <TextBlock Name="lblSoftwareinfo" FontSize="12" Opacity="0.65" Margin="0,2,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </Border>

            <!-- Seiten-Frame -->
            <Frame x:Name="MainFrame" Grid.Row="2"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"/>
        </Grid>
    </Grid>
</Window>
